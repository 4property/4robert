# General runtime configuration
LOG_LEVEL=INFO

# Optional manual fetch configuration
# This program is designed to run in multi-WordPress mode.
# These values are only used for manual/local fetch workflows.
# In webhook mode, each WordPress sender provides its own site_id and is routed independently.
WORDPRESS_LINK=https://example-estate.ie/wp-json/wp/v2/property
WORDPRESS_PER_PAGE=100
REQUEST_TIMEOUT_SECONDS=30

# Webhook transport and security
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/webhooks/wordpress/property
WEBHOOK_SITE_ID_HEADER=X-WordPress-Site-ID
WEBHOOK_TIMESTAMP_HEADER=X-WordPress-Timestamp
WEBHOOK_SIGNATURE_HEADER=X-WordPress-Signature
WEBHOOK_GOHIGHLEVEL_LOCATION_ID_HEADER=X-GoHighLevel-Location-ID
WEBHOOK_GOHIGHLEVEL_ACCESS_TOKEN_HEADER=X-GoHighLevel-Access-Token
# Keep this false in production unless you explicitly want unsigned local testing.
WEBHOOK_DISABLE_SECURITY=false
# Comma-separated site_id=secret pairs for every WordPress sender allowed to post webhooks.
# Add one entry per WordPress site that will post into this shared service.
WEBHOOK_SITE_SECRETS=example-estate.ie=change-me,second-estate.ie=change-me-too
WEBHOOK_WORKER_COUNT=1
WEBHOOK_JOB_MAX_ATTEMPTS=3
WEBHOOK_JOB_RETRY_BACKOFF_SECONDS=30
WEBHOOK_QUEUE_POLL_INTERVAL_SECONDS=0.5
WEBHOOK_QUEUE_LEASE_SECONDS=900
WEBHOOK_SHUTDOWN_TIMEOUT_SECONDS=10
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_MAX_PAYLOAD_BYTES=1000000

# Database
SQLITE_BUSY_TIMEOUT_MS=5000

# Social publishing
SOCIAL_PUBLISHING_ENABLED=true
# When true, videos are rendered and stored locally but not published externally.
SOCIAL_PUBLISHING_LOCAL_ONLY=false
SOCIAL_PUBLISHING_DEFAULT_PLATFORMS=tiktok,instagram,linkedin,youtube
SOCIAL_PUBLISHING_RETRY_ATTEMPTS=3
SOCIAL_PUBLISHING_RETRY_BACKOFF_SECONDS=1.5
SOCIAL_PUBLISHING_YOUTUBE_POST_TYPE=post
SOCIAL_PUBLISHING_POST_STATUS_POLL_ATTEMPTS=10
SOCIAL_PUBLISHING_POST_STATUS_POLL_INTERVAL_SECONDS=3.0
# This stays multi-site friendly because it uses the incoming site_id and slug from each webhook.
SOCIAL_PUBLISHING_PROPERTY_URL_TEMPLATE=https://{site_id}/property/{slug}
# Optional comma-separated query params, for example:
# utm_source=tiktok,utm_medium=social,utm_campaign={site_id}-{slug}
SOCIAL_PUBLISHING_PROPERTY_URL_TRACKING_PARAMS=
GO_HIGH_LEVEL_BASE_URL=https://services.leadconnectorhq.com
GO_HIGH_LEVEL_API_VERSION=2021-07-28

# Reel rendering
REEL_TOTAL_DURATION_SECONDS=43
REEL_SECONDS_PER_SLIDE=5
REEL_INTRO_DURATION_SECONDS=3
# Relative paths are resolved from the project root.
REEL_SUBTITLE_FONT_PATH=assets/fonts/Inter/static/Inter_28pt-Bold.ttf
# Subtitle size increased by 50% from the previous 36px default.
REEL_SUBTITLE_FONT_SIZE=54

# Gemini image analysis
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=90
GEMINI_RETRY_ATTEMPTS=6
